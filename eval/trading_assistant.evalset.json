            "role": "model",
            "parts": [{"text": "The current price of BTCUSDT is available from the market data tool."}]
          },
          "intermediate_data": {
            "tool_uses": [
              {"name": "get_price", "args": {"symbol": "BTC"}}
            ]
          }
        }
      ],
      "session_input": {
        "app_name": "trading_bot",
        "user_id": "user1",
        "state": {"user_id": "user1"}
      }
    },
